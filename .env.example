# Port server Express
PORT=3001

# Kunci rahasia untuk autentikasi endpoint (header: Authorization: Bearer <API_KEY>)
API_KEY=gantidengankuncirahasiaanda

# URL webhook AutoFlow tujuan untuk meneruskan pesan masuk
AUTOFLOW_WEBHOOK_URL=

# Folder penyimpanan sesi autentikasi WhatsApp (persisten)
AUTH_FOLDER=./auth_info_baileys

# Daftar URL asal yang diizinkan untuk bypass CORS (pisahkan dengan koma jika lebih dari satu)
CORS_ORIGINS=

# API key Ably untuk publish balasan masuk secara realtime ke frontend (ambil dari dashboard Ably)
ABLY_API_KEY=
